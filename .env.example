# Inference Provider Configuration
# Copy to .env and fill in your values
# DO NOT commit .env to version control

# Venice.ai (private inference, no data retention)
# Uncomment and add your key to enable
# VENICE_API_KEY=your-venice-api-key-here
# VENICE_MODEL=qwen3-5-35b-a3b

# To use Venice with Hermes, add to your ~/.hermes/config.yaml:
# provider: openai
# base_url: https://api.venice.ai/v1
# api_key: ${VENICE_API_KEY}
# model: ${VENICE_MODEL}

# Local Ollama (zero data leakage)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Local vLLM
# VLLM_BASE_URL=http://localhost:8000/v1
